<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- App Theme -->
    <style name="Theme.WellnessBuddy" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_dark_green</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/secondary_green</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar & background -->
        <item name="android:statusBarColor">@color/primary_dark_green</item>
        <item name="android:windowBackground">@color/background_light</item>

        <!-- Popup menu -->
        <item name="popupMenuStyle">@style/CustomPopupMenu</item>
        <item name="android:popupMenuStyle">@style/CustomPopupMenu</item>
    </style>

    <!-- Optional: NoActionBar variant -->
    <style name="Theme.WellnessBuddy.NoActionBar" parent="Theme.WellnessBuddy" />

</resources>
